
# Load parameters
loadAmberParams model_ligand/setup/molecules/model_ligand/model_ligand.frcmod
source leaprc.protein.ff14SB
source leaprc.gaff2
source leaprc.water.tip3p

# Load molecules
model_ligand = loadMol2 model_ligand/setup/molecules/model_ligand/model_ligand.gaff.mol2

# Solvate systems
solvateBox model_ligand TIP3PBOX 10 iso
addIonsRand model_ligand K+ 0
addIonsRand model_ligand Cl- 0
addIonsRand model_ligand K+ 3
addIonsRand model_ligand Cl- 3

# Check charge
check model_ligand

# Save prmtop and inpcrd files
saveAmberParm model_ligand model_ligand/setup/systems/model_sys/solvent.prmtop model_ligand/setup/systems/model_sys/solvent.inpcrd
savePDB model_ligand model_ligand/setup/systems/model_sys/solvent.pdb

quit
